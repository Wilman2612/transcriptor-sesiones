# Backend de transcripción: "local" usa faster-whisper, "openai" usa OpenAI API
WHISPER_BACKEND=local

# Modelo de faster-whisper: tiny/base/small/medium/large-v3
# El instalador lo elige automáticamente según tu hardware
WHISPER_MODEL=medium

# Dispositivo: auto (detecta GPU si hay), cpu, cuda
WHISPER_DEVICE=auto

# Requerido solo si WHISPER_BACKEND=openai
OPENAI_API_KEY=

# Umbral de confianza (0-1): segmentos bajo este valor se marcan como [inaudible]
CONFIDENCE_THRESHOLD=0.4

# Duración máxima de cada chunk en segundos (default 13 min)
CHUNK_MAX_SECONDS=780

# Puerto del servidor web
PORT=8000

# Idioma de transcripción
WHISPER_LANGUAGE=es
